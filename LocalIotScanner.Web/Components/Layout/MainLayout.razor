@inherits LayoutComponentBase
@using LocalIotScanner.Web.Components.Layout

<div class="d-flex min-vh-100 bg-light">
    <NavMenu />

    <main class="flex-grow-1" style="margin-left: 250px;">
        <article class="p-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" class="bg-danger text-white px-4 py-2 shadow" style="display: none; position: fixed; bottom: 0; width: 100%; z-index: 1000;">
    <div class="container d-flex justify-content-between align-items-center">
        <span>An unhandled error has occurred.</span>
        <div>
            <a href="" class="text-white text-decoration-underline me-3">Reload</a>
            <span class="dismiss" style="cursor: pointer;" onclick="document.getElementById('blazor-error-ui').style.display='none'">🗙</span>
        </div>
    </div>
</div>