@page "/history"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using LocalIotScanner.Core.Models
@using LocalIotScanner.Web.Services
@inject ScannerDbContext DbContext
@inject TranslationService T
@implements IDisposable

<div class="container mt-4">
    <h2><i class="bi bi-clock-history"></i> @T["Hist_Title"]</h2>
    <p class="text-muted">@T["Hist_Subtitle"]</p>

    @if (isLoading)
    {
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">@T["Hist_Loading"]</span>
        </div>
    }
    else if (!auditSessions.Any())
    {
        <div class="alert alert-info">
            @T["Hist_NoData"]
        </div>
    }
    else
    {
        <div class="accordion" id="auditHistoryAccordion">
            @foreach (var session in auditSessions)
            {
                bool isExpanded = expandedSessions.Contains(session.Id);
                string buttonClass = isExpanded ? "accordion-button" : "accordion-button collapsed";
                string contentClass = isExpanded ? "accordion-collapse collapse show" : "accordion-collapse collapse";

                <div class="accordion-item mb-2 border rounded">
                    <h2 class="accordion-header">
                        <button class="@buttonClass" type="button" @onclick="() => ToggleSession(session.Id)">
                            <div class="d-flex justify-content-between w-100 pe-3 align-items-center">
                                <span>
                                    <strong>@session.Timestamp.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</strong>
                                    <span class="text-muted ms-2">(@session.Subnet)</span>
                                </span>
                                <span>
                                    @T["Hist_Hosts"]: <span class="badge bg-secondary me-3">@session.TotalHostsFound</span>
                                    @T["Dash_OverallRisk"]: @GetRiskBadge(session.OverallRiskScore)
                                </span>
                            </div>
                        </button>
                    </h2>

                    <div class="@contentClass">
                        <div class="accordion-body bg-light">
                            @if (!session.Devices.Any())
                            {
                                <p class="text-muted mb-0">@T["Hist_NoDevices"]</p>
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table table-sm table-bordered bg-white mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th>@T["Hist_ColIP"]</th>
                                                <th>@T["Hist_ColType"]</th>
                                                <th>@T["Hist_ColPorts"]</th>
                                                <th>@T["Hist_ColVulns"]</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var device in session.Devices)
                                            {
                                                <tr>
                                                    <td class="fw-bold">@device.IpAddress</td>
                                                    <td>@device.DeviceType</td>
                                                    <td>
                                                        @foreach (var port in device.ScannedPorts.Where(p => p.State == "Open"))
                                                        {
                                                            <span class="badge bg-info text-dark me-1">@port.PortNumber/tcp (@port.DetectedService)</span>
                                                        }
                                                    </td>
                                                    <td>
                                                        @{
                                                            var vulns = device.ScannedPorts.SelectMany(p => p.Vulnerabilities).ToList();
                                                            if (!vulns.Any())
                                                            {
                                                                <span class="text-success"><i class="bi bi-shield-check"></i> @T["Dash_Secure"]</span>
                                                            }
                                                            else
                                                            {
                                                                <ul class="mb-0 ps-3">
                                                                    @foreach (var v in vulns)
                                                                    {
                                                                        <li class="text-danger small"><strong>@T[v.Title]</strong> (@T[v.SeverityLevel])</li>
                                                                    }
                                                                </ul>
                                                            }
                                                        }
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<AuditSession> auditSessions = new();
    private bool isLoading = true;
    private HashSet<int> expandedSessions = new();

    protected override async Task OnInitializedAsync()
    {
        T.OnLanguageChanged += StateHasChanged;

        auditSessions = await DbContext.AuditSessions
            .Include(s => s.Devices)
                .ThenInclude(d => d.ScannedPorts)
                    .ThenInclude(p => p.Vulnerabilities)
            .OrderByDescending(s => s.Timestamp)
            .ToListAsync();

        isLoading = false;
    }

    public void Dispose()
    {
        T.OnLanguageChanged -= StateHasChanged;
    }

    private void ToggleSession(int sessionId)
    {
        if (expandedSessions.Contains(sessionId))
        {
            expandedSessions.Remove(sessionId);
        }
        else
        {
            expandedSessions.Add(sessionId);
        }
    }

    private RenderFragment GetRiskBadge(string riskScore) => __builder =>
    {
        var badgeClass = riskScore.ToLower() switch
        {
            "critical" or "high" => "bg-danger",
            "medium" => "bg-warning text-dark",
            "low" => "bg-success",
            _ => "bg-secondary"
        };

        // Tłumaczenie etykiety wewnątrz odznaki
        <span class="badge @badgeClass">@T[riskScore]</span>
    };
}