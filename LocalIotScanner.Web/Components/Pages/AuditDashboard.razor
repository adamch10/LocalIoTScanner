@page "/"
@rendermode InteractiveServer
@using LocalIotScanner.Core.Interfaces
@using LocalIotScanner.Core.Models
@using LocalIotScanner.Core.Utils
@inject IAuditOrchestratorService Orchestrator

<div class="container mt-4">
    <div class="row mb-3">
        <div class="col-md-12 text-center">
            <h2 class="fw-bold"><i class="bi bi-shield-lock text-success"></i> Local Network Security Audit</h2>
            <p class="text-muted">One-click vulnerability assessment for your connected devices.</p>
        </div>
    </div>

    <div class="card shadow-sm mb-4 border-0 bg-white">
        <div class="card-body text-center p-4">
            
            <div class="btn-group mb-4" role="group" aria-label="Scan Profile Selection">
                <input type="radio" class="btn-check" name="scanProfile" id="quickProfile" autocomplete="off" checked="@(scanProfile == "Quick")" @onchange="@(() => SetProfile("Quick"))" disabled="@isScanning">
                <label class="btn btn-outline-primary px-4" for="quickProfile">
                    <i class="bi bi-lightning-charge"></i> Quick Scan
                </label>

                <input type="radio" class="btn-check" name="scanProfile" id="extendedProfile" autocomplete="off" checked="@(scanProfile == "Extended")" @onchange="@(() => SetProfile("Extended"))" disabled="@isScanning">
                <label class="btn btn-outline-primary px-4" for="extendedProfile">
                    <i class="bi bi-search"></i> Extended Scan
                </label>
            </div>

            <p class="small text-muted mb-4">
                @if (scanProfile == "Quick") {
                    <span>Scans the most common IoT ports (HTTP, SSH, Telnet, FTP) for rapid assessment.</span>
                } else {
                    <span>Scans a comprehensive list of ports including databases, media streams (RTSP), and remote desktops.</span>
                }
            </p>

            <button class="btn btn-success btn-lg px-5 py-3 rounded-pill shadow" @onclick="StartAuditAsync" disabled="@isScanning" style="font-size: 1.2rem;">
                @if (isScanning)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                    <span>Scanning Network...</span>
                }
                else
                {
                    <span><i class="bi bi-play-circle-fill me-2"></i> Start Audit</span>
                }
            </button>

            <div class="mt-3">
                <button class="btn btn-link text-decoration-none text-muted small" type="button" @onclick="ToggleAdvanced" disabled="@isScanning">
                    <i class="bi @(showAdvanced ? "bi-chevron-up" : "bi-chevron-down")"></i> Advanced Settings
                </button>
            </div>

            @if (showAdvanced)
            {
                <div class="mt-3 p-3 bg-light rounded text-start border">
                    <div class="row">
                        <div class="col-md-4">
                            <label class="form-label fw-bold small">Target Subnet</label>
                            <input type="text" class="form-control form-control-sm" @bind="targetSubnet" disabled="@isScanning" />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label fw-bold small">Target Ports (Comma Separated)</label>
                            <input type="text" class="form-control form-control-sm" @bind="targetPortsString" disabled="@isScanning" />
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    @if (isScanning || currentProgress.ProgressPercentage > 0)
    {
        <div class="alert alert-info mb-4 shadow-sm">
            <strong>Status:</strong> @currentProgress.StatusMessage
            <div class="progress mt-2" style="height: 20px;">
                <div class="progress-bar progress-bar-striped progress-bar-animated bg-info" 
                     role="progressbar" 
                     style="width: @(currentProgress.ProgressPercentage)%" 
                     aria-valuenow="@currentProgress.ProgressPercentage" 
                     aria-valuemin="0" 
                     aria-valuemax="100">
                    @currentProgress.ProgressPercentage%
                </div>
            </div>
            <div class="mt-2 small text-dark">
                <span class="badge bg-secondary me-2">Devices Found: @currentProgress.DevicesDiscovered</span>
                <span class="badge bg-danger">Vulnerabilities: @currentProgress.VulnerabilitiesFound</span>
            </div>
        </div>
    }

@if (completedSession != null)
    {
        <div class="card shadow-sm border-success mb-5">
            <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0"><i class="bi bi-check-circle-fill me-2"></i> Audit Complete</h5>
                <span class="badge bg-light text-dark fs-6">Overall Risk: @completedSession.OverallRiskScore</span>
            </div>
            <div class="card-body p-3">
                
                <div class="accordion" id="dashboardResultsAccordion">
                    @foreach (var device in completedSession.Devices)
                    {
                        var openPorts = device.ScannedPorts.Count(p => p.State == "Open");
                        var vulns = device.ScannedPorts.SelectMany(p => p.Vulnerabilities).ToList();
                        
                        bool isExpanded = expandedDevices.Contains(device.IpAddress);
                        string buttonClass = isExpanded ? "accordion-button" : "accordion-button collapsed";
                        string contentClass = isExpanded ? "accordion-collapse collapse show" : "accordion-collapse collapse";

                        <div class="accordion-item mb-2 border rounded">
                            <h2 class="accordion-header">
                                <button class="@buttonClass" type="button" @onclick="() => ToggleDevice(device.IpAddress)">
                                    <div class="d-flex justify-content-between w-100 pe-3 align-items-center">
                                        <span>
                                            <strong><i class="bi bi-hdd-network me-2"></i>@device.IpAddress</strong> 
                                            <span class="text-muted small ms-2">(@device.DeviceType)</span>
                                        </span>
                                        <span>
                                            <span class="badge bg-info text-dark me-2">@openPorts Ports Open</span>
                                            @if (vulns.Any())
                                            {
                                                <span class="badge bg-danger">@vulns.Count Issues</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success"><i class="bi bi-shield-check"></i> Secure</span>
                                            }
                                        </span>
                                    </div>
                                </button>
                            </h2>
                            <div class="@contentClass">
                                <div class="accordion-body bg-light p-3">
                                    @if (openPorts == 0)
                                    {
                                        <div class="text-success text-center py-2">
                                            <i class="bi bi-shield-check fs-4 d-block mb-1"></i>
                                            No open ports detected. This device appears secure.
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="table-responsive">
                                            <table class="table table-sm bg-white border mb-0">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th style="width: 25%">Port / Service</th>
                                                        <th style="width: 75%">Vulnerabilities & Mitigations</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach(var port in device.ScannedPorts.Where(p => p.State == "Open"))
                                                    {
                                                        <tr>
                                                            <td>
                                                                <strong class="text-primary">@port.PortNumber / @port.Protocol</strong><br/>
                                                                <small class="text-muted">@port.DetectedService</small>
                                                            </td>
                                                            <td>
                                                                @if(!port.Vulnerabilities.Any())
                                                                {
                                                                    <span class="text-muted small">No known vulnerabilities detected for this service.</span>
                                                                }
                                                                else
                                                                {
                                                                    <ul class="mb-0 ps-3">
                                                                        @foreach(var v in port.Vulnerabilities)
                                                                        {
                                                                            <li class="mb-2">
                                                                                <strong class="text-danger">@v.Title</strong> 
                                                                                <span class="badge bg-danger ms-1">@v.SeverityLevel</span><br/>
                                                                                <small class="text-dark">@v.Description</small><br/>
                                                                                <small class="text-success fw-bold"><i class="bi bi-wrench"></i> Fix: @v.Mitigation</small>
                                                                            </li>
                                                                        }
                                                                    </ul>
                                                                }
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>

            </div>
        </div>
    }
</div>

@code {
    private string targetSubnet = string.Empty;
    private string targetPortsString = string.Empty;
    
    private string scanProfile = "Quick";
    private bool showAdvanced = false;
    private bool isScanning = false;
    
    private ScanProgress currentProgress = new();
    private AuditSession? completedSession;

    private HashSet<string> expandedDevices = new();

    // Define port profiles
    private const string QuickPorts = "21, 22, 23, 80, 443, 1883, 8080"; 
    private const string ExtendedPorts = "21, 22, 23, 25, 53, 80, 110, 111, 135, 139, 143, 443, 445, 554, 993, 995, 1883, 3306, 3389, 5900, 8080, 8443"; // Includes DBs, RDP, VNC, RTSP (554 - IP Cameras)

    protected override void OnInitialized()
    {
        // 1. Auto-detect the subnet on startup
        targetSubnet = NetworkHelper.GetLocalIPv4Subnet();
        
        // 2. Set default ports
        targetPortsString = QuickPorts;
    }

    private void ToggleDevice(string ipAddress)
    {
        if (expandedDevices.Contains(ipAddress))
        {
            expandedDevices.Remove(ipAddress);
        }
        else
        {
            expandedDevices.Add(ipAddress);
        }
    }

    private void SetProfile(string profile)
    {
        scanProfile = profile;
        targetPortsString = profile == "Quick" ? QuickPorts : ExtendedPorts;
    }

    private void ToggleAdvanced()
    {
        showAdvanced = !showAdvanced;
    }

    private async Task StartAuditAsync()
    {
        isScanning = true;
        completedSession = null;
        expandedDevices.Clear();
        currentProgress = new ScanProgress { StatusMessage = "Initializing scanner..." };

        var ports = targetPortsString.Split(',')
                                     .Select(p => int.TryParse(p.Trim(), out var parsed) ? parsed : -1)
                                     .Where(p => p > 0)
                                     .ToList();

        var progressHandler = new Progress<ScanProgress>(update =>
        {
            currentProgress = update;
            InvokeAsync(StateHasChanged);
        });

        try
        {
            completedSession = await Orchestrator.RunFullAuditAsync(targetSubnet, ports, CancellationToken.None, progressHandler);
            
            currentProgress.ProgressPercentage = 100;
            currentProgress.StatusMessage = "Audit completed successfully.";
        }
        catch (Exception ex)
        {
            currentProgress.StatusMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isScanning = false;
        }
    }
}