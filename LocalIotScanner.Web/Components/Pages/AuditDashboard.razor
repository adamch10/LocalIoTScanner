@page "/"
@rendermode InteractiveServer
@using LocalIotScanner.Core.Interfaces
@using LocalIotScanner.Core.Models
@inject IAuditOrchestratorService Orchestrator

<div class="container mt-4">
    <div class="row">
        <div class="col-md-12">
            <h2><i class="bi bi-shield-lock"></i> Local IoT Security Scanner</h2>
            <p class="text-muted">Automated vulnerability assessment for SOHO networks.</p>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Target Subnet (CIDR format)</label>
                    <input type="text" class="form-control" @bind="targetSubnet" disabled="@isScanning" placeholder="e.g., 192.168.1.0/24" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Common IoT Ports to Scan</label>
                    <input type="text" class="form-control" @bind="targetPortsString" disabled="@isScanning" />
                </div>
                <div class="col-md-2">
                    <button class="btn btn-primary w-100" @onclick="StartAuditAsync" disabled="@isScanning">
                        @if (isScanning)
                        {
                            <span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>
                            <span> Scanning...</span>
                        }
                        else
                        {
                            <span><i class="bi bi-play-fill"></i> Run Audit</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (isScanning || currentProgress.ProgressPercentage > 0)
    {
        <div class="alert alert-info mb-4">
            <strong>Status:</strong> @currentProgress.StatusMessage
            <div class="progress mt-2" style="height: 20px;">
                <div class="progress-bar progress-bar-striped progress-bar-animated"
                     role="progressbar"
                     style="width: @(currentProgress.ProgressPercentage)%"
                     aria-valuenow="@currentProgress.ProgressPercentage"
                     aria-valuemin="0"
                     aria-valuemax="100">
                    @currentProgress.ProgressPercentage%
                </div>
            </div>
            <div class="mt-2 small">
                <span class="badge bg-secondary me-2">Devices Found: @currentProgress.DevicesDiscovered</span>
                <span class="badge bg-danger">Vulnerabilities: @currentProgress.VulnerabilitiesFound</span>
            </div>
        </div>
    }

    @if (completedSession != null)
    {
        <div class="card shadow-sm border-success">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">Audit Complete - Overall Risk: <strong>@completedSession.OverallRiskScore</strong></h5>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>IP Address</th>
                            <th>Device Type</th>
                            <th>Open Ports</th>
                            <th>Critical Findings</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var device in completedSession.Devices)
                        {
                            var openPorts = device.ScannedPorts.Count(p => p.State == "Open");
                            var vulns = device.ScannedPorts.SelectMany(p => p.Vulnerabilities).Count();

                            <tr>
                                <td><strong>@device.IpAddress</strong></td>
                                <td>@device.DeviceType</td>
                                <td><span class="badge bg-info text-dark">@openPorts</span></td>
                                <td>
                                    @if (vulns > 0)
                                    {
                                        <span class="badge bg-danger">@vulns Found</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Secure</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@code {
    private string targetSubnet = "192.168.1.0/24"; // Default for home networks
    private string targetPortsString = "21, 22, 23, 80, 443, 8080";

    private bool isScanning = false;
    private ScanProgress currentProgress = new();
    private AuditSession? completedSession;

    private async Task StartAuditAsync()
    {
        isScanning = true;
        completedSession = null;
        currentProgress = new ScanProgress { StatusMessage = "Initializing scanner..." };

        // Parse the ports from the UI input
        var ports = targetPortsString.Split(',')
                                     .Select(p => int.TryParse(p.Trim(), out var parsed) ? parsed : -1)
                                     .Where(p => p > 0)
                                     .ToList();

        // Create a Progress handler that Blazor can bind to
        var progressHandler = new Progress<ScanProgress>(update =>
        {
            currentProgress = update;
            // Force Blazor to re-render the UI when background updates arrive
            InvokeAsync(StateHasChanged);
        });

        try
        {
            // Execute the backend orchestrator
            completedSession = await Orchestrator.RunFullAuditAsync(targetSubnet, ports, CancellationToken.None, progressHandler);

            currentProgress.ProgressPercentage = 100;
            currentProgress.StatusMessage = "Audit completed successfully.";
        }
        catch (Exception ex)
        {
            currentProgress.StatusMessage = $"Error: {ex.Message}";
        }
        finally
        {
            isScanning = false;
        }
    }
}